{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["oxlint.config.ts", ".oxfmtrc.json"],
  // Turbo runs tasks in strict env mode, which strips undeclared variables from
  // the task environment. propertyConfig reads these at run time: the nightly
  // factor that scales property numRuns, and CI to enable fast-check verbose
  // reporting. Without passing them through, the nightly sweep would silently
  // run at factor 1.
  "globalPassThroughEnv": ["CI", "PROPERTY_TEST_NUM_RUNS_FACTOR"],
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "typegen": {
      "dependsOn": ["transit"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": [".cache/tsbuildinfo.json"]
    },
    "@stll/landing#typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "lint:fix": {
      "dependsOn": ["transit"],
      "cache": false
    },
    "format": {
      "dependsOn": ["transit"]
    },
    "i18n:check": {
      "dependsOn": ["transit"],
      "cache": false
    },
    "i18n:sync": {
      "dependsOn": ["transit"],
      "cache": false
    },
    "test": {
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$"]
    },
    "test:property": {
      "dependsOn": [],
      "inputs": ["$TURBO_DEFAULT$"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
