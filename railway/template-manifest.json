{
  "metadata": {
    "name": "stella",
    "category": "AI/ML",
    "description": "Self-host stella with web, API, Postgres, Redis, and object storage.",
    "image": "https://raw.githubusercontent.com/stella/stella/main/apps/desktop/icon.iconset/icon_512x512.png",
    "readmeFile": "railway/template-readme.md"
  },
  "source": {
    "repository": "https://github.com/stella/stella",
    "branch": "main"
  },
  "buckets": {
    "stella-files": {}
  },
  "services": {
    "Postgres": {
      "variables": {
        "DATABASE_PUBLIC_URL": "postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}/${{PGDATABASE}}",
        "DATABASE_URL": "postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}",
        "PGDATA": "/var/lib/postgresql/data/pgdata",
        "PGDATABASE": "${{POSTGRES_DB}}",
        "PGHOST": "${{RAILWAY_PRIVATE_DOMAIN}}",
        "PGPASSWORD": "${{POSTGRES_PASSWORD}}",
        "PGPORT": "5432",
        "PGUSER": "${{POSTGRES_USER}}",
        "POSTGRES_DB": "railway",
        "POSTGRES_PASSWORD": "${{secret(32, \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ\")}}",
        "POSTGRES_USER": "postgres",
        "RAILWAY_DEPLOYMENT_DRAINING_SECONDS": "60",
        "SSL_CERT_DAYS": "820"
      }
    },
    "Redis": {
      "variables": {
        "REDISHOST": "${{RAILWAY_PRIVATE_DOMAIN}}",
        "REDISPASSWORD": "${{REDIS_PASSWORD}}",
        "REDISPORT": "6379",
        "REDISUSER": "default",
        "REDIS_PASSWORD": "${{secret(32, \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ\")}}",
        "REDIS_PUBLIC_URL": "redis://default:${{REDIS_PASSWORD}}@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}",
        "REDIS_URL": "redis://${{REDISUSER}}:${{REDIS_PASSWORD}}@${{REDISHOST}}:${{REDISPORT}}"
      }
    },
    "api": {
      "configFile": "/railway.json",
      "publicNetworking": true,
      "requiredUserInputs": {
        "SMTP_PASSWORD": "SMTP password or API key for sign-in and invitation emails.",
        "TRANSACTIONAL_EMAIL_FROM": "From address for transactional emails."
      },
      "variables": {
        "BETTER_AUTH_SECRET": "${{secret(64, \"abcdef0123456789\")}}",
        "BETTER_AUTH_URL": "https://${{api.RAILWAY_PUBLIC_DOMAIN}}",
        "CONTENT_ENCRYPTION_KEY": "${{secret(64, \"abcdef0123456789\")}}",
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}",
        "FRONTEND_URL": "https://${{web.RAILWAY_PUBLIC_DOMAIN}}",
        "GOTENBERG_PASSWORD": "${{gotenberg.GOTENBERG_API_BASIC_AUTH_PASSWORD}}",
        "GOTENBERG_URL": "http://${{gotenberg.RAILWAY_PRIVATE_DOMAIN}}:3000",
        "GOTENBERG_USERNAME": "${{gotenberg.GOTENBERG_API_BASIC_AUTH_USERNAME}}",
        "PUBLIC_URL": "https://${{api.RAILWAY_PUBLIC_DOMAIN}}",
        "REDIS_URL": "${{Redis.REDIS_URL}}",
        "S3_ACCESS_KEY_ID": "${{stella-files.ACCESS_KEY_ID}}",
        "S3_BUCKET": "${{stella-files.BUCKET}}",
        "S3_ENDPOINT": "${{stella-files.ENDPOINT}}",
        "S3_REGION": "${{stella-files.REGION}}",
        "S3_SECRET_ACCESS_KEY": "${{stella-files.SECRET_ACCESS_KEY}}",
        "SMTP_HOST": "smtp.resend.com",
        "SMTP_PASSWORD": "smtp-password",
        "SMTP_PORT": "587",
        "SMTP_USERNAME": "resend",
        "TRANSACTIONAL_EMAIL_FROM": "noreply@example.invalid"
      }
    },
    "web": {
      "configFile": "/railway/web.railway.json",
      "publicNetworking": true,
      "variables": {
        "PUBLIC_API_URL": "https://${{api.RAILWAY_PUBLIC_DOMAIN}}",
        "PUBLIC_APP_URL": "https://${{web.RAILWAY_PUBLIC_DOMAIN}}"
      }
    },
    "gotenberg": {
      "publicNetworking": false,
      "variables": {
        "API_ENABLE_BASIC_AUTH": "true",
        "GOTENBERG_API_BASIC_AUTH_PASSWORD": "${{secret(64, \"abcdef0123456789\")}}",
        "GOTENBERG_API_BASIC_AUTH_USERNAME": "${{secret(32, \"abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ\")}}"
      }
    }
  }
}
