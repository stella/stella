{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./node_modules/ultracite/config/oxlint/core/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/react/.oxlintrc.json"
  ],
  "ignorePatterns": ["**/routeTree.gen.ts", "**/*.config.js"],
  "rules": {
    // Override ultracite defaults for Stella
    "no-console": "warn",
    "no-shadow": "error",
    "require-await": "error",
    "no-useless-catch": "error",
    "no-non-null-assertion": "error",

    "typescript/no-explicit-any": "error",
    "typescript/no-dynamic-delete": "error",
    "typescript/consistent-type-definitions": ["error", "type"],

    "unicorn/no-useless-undefined": "error",

    "react/no-forward-ref": "error",
    "react/rules-of-hooks": "error",

    "import/no-cycle": "error",

    // --- Disabled ultracite defaults ---
    // General JS
    "sort-keys": "off",
    "no-plusplus": "off",
    "no-inline-comments": "off",
    "max-statements": "off",
    "prefer-destructuring": "off",
    "no-void": "off",
    "no-negated-condition": "off",
    "no-eq-null": "off",
    "no-nested-ternary": "off",
    "no-use-before-define": "off",
    "no-useless-return": "off",
    "no-empty-function": "off",
    "no-warning-comments": "off",
    "no-unexpected-multiline": "off",
    "no-promise-executor-return": "off",
    "no-useless-concat": "off",
    "max-classes-per-file": "off",
    "class-methods-use-this": "off",
    "no-unmodified-loop-condition": "off",
    "complexity": "off",
    // func-style: Stella uses both declarations and expressions
    "func-style": "off",

    // TypeScript
    "typescript/no-inferrable-types": "off",

    // Unicorn
    "unicorn/switch-case-braces": "off",
    "unicorn/number-literal-case": "off",
    "unicorn/escape-case": "off",
    "unicorn/no-hex-escape": "off",
    "unicorn/prefer-string-replace-all": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/filename-case": "off",
    "unicorn/prefer-response-static-json": "off",
    "unicorn/no-immediate-mutation": "off",
    "unicorn/prefer-ternary": "off",
    "unicorn/no-array-reduce": "off",
    "unicorn/no-useless-spread": "off",
    "unicorn/no-await-expression-member": "off",
    "unicorn/no-nested-ternary": "off",

    // React perf
    "react_perf/jsx-no-new-function-as-prop": "off",
    "react_perf/jsx-no-new-object-as-prop": "off",
    "react_perf/jsx-no-new-array-as-prop": "off",

    // React
    "react/no-array-index-key": "off",
    "react/no-children-prop": "off",
    "react/no-danger": "off",
    "react/jsx-handler-names": "off",

    "import/no-named-as-default-member": "off",
    "import/no-named-as-default": "off",
    "import/no-relative-parent-imports": "off",
    "import/no-namespace": "off",

    // Promise
    "promise/prefer-await-to-then": "off",
    "promise/prefer-await-to-callbacks": "off",
    "promise/avoid-new": "off",

    // JSDoc
    "jsdoc/require-param-type": "off",

    // JSX accessibility
    "jsx-a11y/no-static-element-interactions": "off",
    "jsx-a11y/click-events-have-key-events": "off",

    // Jest (top-level; repeated in test-file override below)
    "jest/no-conditional-in-test": "off",
    "jest/no-conditional-expect": "off",
    "jest/require-hook": "off",
    "jest/prefer-each": "off",
    "jest/valid-title": "off",

    // Rules without oxlint equivalents (tracked for future):
    // - noSecrets (entropy-based secret detection)
    // - noDuplicateDependencies (package.json lint)
    // - noJsxLiterals (JSX string literal enforcement)
    // - useSimplifiedLogicExpression
    // - noExcessiveCognitiveComplexity
    // - useErrorCause
    // - noScriptUrl (partially covered by jsx-a11y)

    // --- Type-aware suppressions (temporarily disabled to adopt oxlint-tsgolint incrementally) ---
    "typescript/strict-boolean-expressions": "off",
    "typescript/no-confusing-void-expression": "off",
    "typescript/promise-function-async": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "typescript/await-thenable": "off",
    "typescript/prefer-nullish-coalescing": "off",
    "typescript/no-unsafe-assignment": "off",
    "typescript/use-unknown-in-catch-callback-variable": "off",
    "typescript/unbound-method": "off",
    "typescript/only-throw-error": "off",
    "typescript/no-base-to-string": "off",
    "typescript/no-unsafe-member-access": "off",
    "typescript/no-unsafe-argument": "off",
    "typescript/return-await": "off",
    "typescript/switch-exhaustiveness-check": "off",
    "typescript/no-deprecated": "off",
    "typescript/no-misused-spread": "off",
    "typescript/no-unsafe-return": "off",
    "typescript/no-unsafe-call": "off",
    "typescript/no-unnecessary-boolean-literal-compare": "off",
    "typescript/non-nullable-type-assertion-style": "off",
    "typescript/restrict-template-expressions": "off",
    "typescript/prefer-reduce-type-parameter": "off",
    "eqeqeq": ["error", "always", { "null": "ignore" }]
  },
  "overrides": [
    {
      "files": [
        "apps/api/src/handlers/docx/**",
        "apps/web/src/routes/_protected.workspaces/$workspaceId/-components/pdf/pdf-viewer.tsx"
      ],
      "rules": {
        "unicorn/prefer-dom-node-remove": "off",
        "unicorn/prefer-dom-node-append": "off",
        "unicorn/prefer-modern-dom-apis": "off"
      }
    },
    {
      "files": [
        "apps/web/scripts/**",
        "apps/api/scripts/**",
        "scripts/**",
        "packages/scripts/**"
      ],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": [
        "**/*.{test,spec}.{ts,tsx,js,jsx}",
        "**/__tests__/**/*.{ts,tsx,js,jsx}"
      ],
      "plugins": ["jest", "vitest"],
      "rules": {
        "jest/no-hooks": "off",
        "jest/no-conditional-in-test": "off",
        "jest/no-conditional-expect": "off",
        "jest/max-expects": "off",
        "jest/require-hook": "off",
        "jest/prefer-each": "off",
        "jest/valid-title": "off",
        // Mock functions are often async without await to satisfy interface
        // return types (Promise<T>) without an actual async operation.
        "require-await": "off"
      }
    },
    {
      "files": ["apps/api/src/handlers/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@/api/lib/branded-types",
                "importNames": ["toSafeId"],
                "message": "Handlers must receive SafeId from macros (workspaceAccessMacro, authMacro) or actor session validation, not construct it from raw strings."
              },
              {
                "name": "ai",
                "importNames": ["tool"],
                "message": "Use defineTool from chat-tools.ts instead of tool() directly. defineTool automatically wraps execute with safeExecute."
              }
            ]
          }
        ]
      }
    }
  ]
}
