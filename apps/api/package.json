{
  "name": "@stella/api",
  "version": "0.0.0",
  "module": "src/index.js",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun run docker:dev && bun --port 3001 --watch src/index.ts",
    "docker:dev": "docker compose --profile dev up -d",
    "docker:reset-dev": "docker compose --profile dev down -v && docker compose --profile dev up -d",
    "docker:stop-dev": "docker compose --profile dev down",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "typecheck": "tsgo --noEmit",
    "lint": "bun --bun oxlint --type-aware",
    "format": "oxfmt .",
    "db:push": "bun --bun drizzle-kit push",
    "db:seed-test-user": "bun scripts/seed-test-user.ts",
    "db:seed-dev": "bun scripts/seed-dev.ts",
    "db:seed-templates": "bun scripts/seed-templates.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/valibot": "^2.0.0",
    "@elysiajs/cors": "^1.4.1",
    "@faker-js/faker": "^10.3.0",
    "@hono/node-server": "^1.19.9",
    "@hono/node-ws": "^1.3.0",
    "@kreuzberg/html-to-markdown": "2.28.2",
    "@libpdf/core": "catalog:",
    "@litko/yara-x": "^0.5.0",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@stella/permissions": "workspace:*",
    "@stella/rivet": "workspace:*",
    "@stella/template-conditions": "workspace:*",
    "@stella/transactional": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "ai": "^6.0.104",
    "better-auth": "catalog:",
    "better-result": "catalog:",
    "diff-match-patch": "catalog:",
    "docx": "^9.6.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "1.0.0-beta.15-859cf75",
    "elysia": "catalog:",
    "elysia-rate-limit": "^4.5.0",
    "jsdom": "^28.1.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.2",
    "nanoid": "catalog:",
    "pompelmi": "^0.32.1",
    "posthog-node": "^5.26.0",
    "resend": "^6.9.3",
    "rivetkit": "catalog:rivet",
    "slimdom": "^4.3.5",
    "unpdf": "^1.4.0",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@stella/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/diff-match-patch": "catalog:",
    "@types/jsdom": "^28.0.0",
    "bun-types": "latest",
    "drizzle-kit": "1.0.0-beta.15-859cf75",
    "fast-check": "^4.5.3"
  }
}
