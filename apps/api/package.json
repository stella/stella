    "@stll/template-conditions": "workspace:*",
    "@stll/text-normalize": "workspace:*",
    "@stll/transactional": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "@tanstack/ai": "catalog:",
    "@tanstack/ai-anthropic": "catalog:",
    "@tanstack/ai-bedrock": "catalog:",
    "@tanstack/ai-client": "catalog:",
    "@tanstack/ai-code-mode": "catalog:",
