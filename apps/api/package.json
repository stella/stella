{
  "name": "@stll/api",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "module": "src/server.ts",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "test": "bun test --preload ./src/tests/setup-env.ts",
    "test:property": "bun test --preload ./src/tests/setup-env.ts $(grep -rlF 'fc.assert' src --include='*.test.ts')",
    "dev": "bun run docker:dev && NODE_ENV=development bun --port 3001 --preload ./src/dev/register-mock-ai.ts --watch src/server.ts",
    "docker:dev": "docker compose --profile dev up -d",
    "docker:reset-dev": "docker compose --profile dev down -v && docker compose --profile dev up -d",
    "docker:stop-dev": "docker compose --profile dev down",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "typecheck": "bun ../../packages/scripts/src/tsc-native.ts --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware apps/api",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix apps/api",
    "format": "oxfmt .",
    "canary:ai-provider": "bun --env-file=.env.example scripts/ai-provider-canary.ts",
    "bench:chat-read-surface": "NODE_ENV=development bun scripts/benchmark-chat-read-surface.ts",
    "db:migrate": "bun run --env-file=.env src/db/migrate.ts",
    "db:push": "bun run --env-file=.env drizzle-kit push",
    "db:seed-test-user": "bun scripts/seed-test-user.ts",
    "db:seed-dev": "bun scripts/seed-dev.ts",
    "db:seed-case-law": "bun scripts/seed-case-law.ts",
    "db:seed-templates": "bun scripts/seed-templates.ts",
    "db:backfill-chat-search": "bun scripts/backfill-chat-search.ts",
    "scheduler": "bun src/scheduler/scheduler.ts",
    "dev:scheduler": "bun --watch src/scheduler/scheduler.ts",
    "dev:errors": "tail -F .dev-logs/errors.jsonl"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@aws-sdk/client-sesv2": "^3.1083.0",
    "@aws-sdk/client-sts": "^3.1083.0",
    "@aws-sdk/s3-request-presigner": "^3.1083.0",
    "@better-auth/oauth-provider": "catalog:",
    "@elysiajs/cors": "^1.4.2",
    "@google/genai": "^2.10.0",
    "@libpdf/core": "catalog:",
    "@litko/yara-x": "^0.7.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@opentelemetry/api-logs": "^0.220.0",
    "@react-email/render": "^2.0.10",
    "@sinclair/typebox": "^0.34.50",
    "@stll/ai-catalog": "workspace:*",
    "@stll/anonymize-chat": "workspace:*",
    "@stll/anonymize-data": "catalog:",
    "@stll/anonymize-wasm": "catalog:",
    "@stll/boe": "workspace:*",
    "@stll/business-registries": "workspace:*",
