{
  "name": "@stll/api",
  "version": "0.0.0",
  "module": "src/index.js",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun run docker:dev && bun --port 3001 --watch src/index.ts",
    "docker:dev": "docker compose --profile dev up -d",
    "docker:reset-dev": "docker compose --profile dev down -v && docker compose --profile dev up -d",
    "docker:stop-dev": "docker compose --profile dev down",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "typecheck": "tsgo --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware apps/api",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware --fix apps/api",
    "format": "oxfmt .",
    "db:push": "bun scripts/check-clientless-workspaces.ts && bun --bun drizzle-kit push",
    "db:seed-test-user": "bun scripts/seed-test-user.ts",
    "db:seed-dev": "bun scripts/seed-dev.ts",
    "db:seed-templates": "bun scripts/seed-templates.ts",
    "scheduler": "bun src/scheduler/index.ts",
    "dev:scheduler": "bun --watch src/scheduler/index.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/google-vertex": "^4.0.112",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/valibot": "^2.0.24",
    "@aws-sdk/client-sesv2": "^3.1029.0",
    "@better-auth/oauth-provider": "catalog:",
    "@elysiajs/cors": "^1.4.1",
    "@libpdf/core": "catalog:",
    "@litko/yara-x": "0.5.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openrouter/ai-sdk-provider": "^2.8.0",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@react-email/render": "^2.0.7",
    "@sinclair/typebox": "^0.34.48",
    "@stll/anonymize-wasm": "catalog:",
    "@stll/ares": "workspace:*",
    "@stll/case-law": "workspace:*",
    "@stll/docx-utils": "workspace:*",
    "@stll/feature-flags": "workspace:*",
    "@stll/infosoud": "workspace:*",
    "@stll/permissions": "workspace:*",
    "@stll/skills": "workspace:*",
    "@stll/template-conditions": "workspace:*",
    "@stll/transactional": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "@valibot/to-json-schema": "^1.5.0",
    "ai": "^6.0.166",
    "better-auth": "catalog:",
    "better-result": "catalog:",
    "bullmq": "^5.74.1",
    "cheerio": "^1.2.0",
    "diff": "catalog:",
    "docx": "^9.6.0",
    "domhandler": "^6.0.1",
    "drizzle-orm": "catalog:",
    "elysia": "catalog:",
    "elysia-rate-limit": "^4.6.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.1",
    "jszip": "catalog:",
    "marked": "^18.0.2",
    "nodemailer": "^8.0.5",
    "posthog-node": "^5.29.2",
    "quickjs-emscripten": "^0.32.0",
    "quickjs-emscripten-core": "^0.32.0",
    "slimdom": "^4.3.5",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@faker-js/faker": "^10.3.0",
    "@stll/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "catalog:",
    "fast-check": "catalog:"
  }
}
