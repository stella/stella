{
  "name": "@stll/api",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "module": "src/index.ts",
  "exports": {
    "./types": "./src/types.ts"
  },
  "scripts": {
    "test": "bun test --preload ./src/tests/setup-env.ts",
    "dev": "bun run docker:dev && NODE_ENV=development bun --port 3001 --watch src/index.ts",
    "dev:ai-tools": "devtools",
    "docker:dev": "docker compose --profile dev up -d",
    "docker:reset-dev": "docker compose --profile dev down -v && docker compose --profile dev up -d",
    "docker:stop-dev": "docker compose --profile dev down",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "typecheck": "tsgo --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware apps/api",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix apps/api",
    "format": "oxfmt .",
    "bench:chat-read-surface": "NODE_ENV=development bun scripts/benchmark-chat-read-surface.ts",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:seed-test-user": "bun scripts/seed-test-user.ts",
    "db:seed-dev": "bun scripts/seed-dev.ts",
    "db:seed-templates": "bun scripts/seed-templates.ts",
    "scheduler": "bun src/scheduler/index.ts",
    "dev:scheduler": "bun --watch src/scheduler/index.ts",
    "dev:errors": "tail -F .dev-logs/errors.jsonl"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/azure": "^3.0.66",
    "@ai-sdk/devtools": "^0.0.18",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/google-vertex": "^4.0.130",
    "@ai-sdk/mcp": "^1.0.42",
    "@ai-sdk/mistral": "^3.0.37",
    "@ai-sdk/openai": "^3.0.65",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@ai-sdk/valibot": "^2.0.28",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/client-sesv2": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@better-auth/oauth-provider": "catalog:",
    "@elysiajs/cors": "^1.4.2",
    "@libpdf/core": "catalog:",
    "@litko/yara-x": "0.5.2",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@opentelemetry/api-logs": "^0.218.0",
    "@react-email/render": "^2.0.8",
    "@sinclair/typebox": "^0.34.49",
    "@stll/anonymize-chat": "workspace:*",
    "@stll/anonymize-data": "catalog:",
    "@stll/anonymize-wasm": "catalog:",
    "@stll/ares": "workspace:*",
    "@stll/boe": "workspace:*",
    "@stll/case-law": "workspace:*",
    "@stll/docx-core": "workspace:*",
    "@stll/docx-utils": "workspace:*",
    "@stll/errors": "workspace:*",
    "@stll/folio": "workspace:*",
    "@stll/infosoud": "workspace:*",
    "@stll/money": "workspace:*",
    "@stll/permissions": "workspace:*",
    "@stll/skills": "workspace:*",
    "@stll/template-conditions": "workspace:*",
    "@stll/transactional": "workspace:*",
    "@t3-oss/env-core": "catalog:",
    "@valibot/to-json-schema": "^1.7.0",
    "ai": "^6.0.191",
    "better-auth": "catalog:",
    "better-result": "catalog:",
    "bullmq": "^5.76.10",
    "cheerio": "^1.2.0",
    "client-zip": "^2.5.0",
    "diff": "catalog:",
    "domhandler": "^6.0.1",
    "drizzle-orm": "catalog:",
    "elysia": "catalog:",
    "elysia-rate-limit": "^4.6.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "jszip": "catalog:",
    "marked": "^18.0.4",
    "nodemailer": "^8.0.7",
    "posthog-node": "^5.34.2",
    "quickjs-emscripten": "^0.32.0",
    "quickjs-emscripten-core": "^0.32.0",
    "slimdom": "^4.3.5",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@faker-js/faker": "^10.3.0",
    "@stll/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "catalog:",
    "fast-check": "catalog:"
  }
}
