# Database connection (postgres owner; RLS activated via SET ROLE stella)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/stella"
FRONTEND_URL="http://localhost:3000"
# Public-facing API URL for verification links (defaults to BETTER_AUTH_URL)
# PUBLIC_URL="http://localhost:3001"

# Better Auth
BETTER_AUTH_SECRET="your-secret-at-least-32-chars-long"
BETTER_AUTH_URL="http://localhost:3001"

# Email — provider: "ses" or "smtp"
EMAIL_PROVIDER="smtp"
TRANSACTIONAL_EMAIL_FROM="noreply@example.com"
# SMTP (self-hosted, dev with MailHog/Mailpit on port 1025)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USERNAME=""
SMTP_PASSWORD=""
# AWS SES (when EMAIL_PROVIDER=ses)
# SES_REGION="eu-central-1"
# SES_ACCESS_KEY_ID=""
# SES_SECRET_ACCESS_KEY=""

# S3 (MinIO)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="stella"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"

# Analytics (phc_ disables PostHog)
POSTHOG_KEY="phc_"
POSTHOG_HOST="https://eu.i.posthog.com"
# Optional: enable PostHog events/logs on localhost when using a real key
# POSTHOG_LOCAL_DEBUG="true"
# Optional: also include raw AI prompts and outputs in localhost LLM events
# POSTHOG_LOCAL_DEBUG_AI_CONTENT="true"

# AI
GOOGLE_GENERATIVE_AI_API_KEY="key-test"
USE_MOCK_AI="true"

# Content encryption (extracted file text, 32 bytes hex-encoded)
# Generate: openssl rand -hex 32
# Optional: when absent, extracted content is stored in plaintext
# CONTENT_ENCRYPTION_KEY=""

# Social login — Google (optional)
# GOOGLE_AUTH_CLIENT_ID=""
# GOOGLE_AUTH_CLIENT_SECRET=""

# Social login — Microsoft (optional)
# MICROSOFT_AUTH_CLIENT_ID=""
# MICROSOFT_AUTH_CLIENT_SECRET=""
# MICROSOFT_AUTH_TENANT_ID="common"

# Redis / Valkey (SSE cross-instance broadcasts)
REDIS_URL="redis://localhost:6379"

# Gotenberg (PDF conversion)
GOTENBERG_URL="http://localhost:3003"
GOTENBERG_USERNAME="gotenberg"
GOTENBERG_PASSWORD="gotenberg"
