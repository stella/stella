# API env validation: apps/api/src/env.ts (envBase: apps/api/src/env-base.ts)
# Required = the API will refuse to boot without it. Optional = unset turns the
# feature off, or falls back to a documented default.

# --- Database --------------------------------------------------------------
# Required. Postgres URL used by Drizzle. The connection logs in as the
# `postgres` owner and is downgraded to the `stella` role per request, which is
# what activates row-level security. In dev, the dev-runner overrides the host
# port when STELLA_INFRA_OFFSET / --infra-offset is set.
DATABASE_URL="postgres://postgres:postgres@localhost:5432/stella"

# --- Public URLs -----------------------------------------------------------
# Required. The web app's base URL. Used to build absolute links in
# transactional emails and as the trusted origin for redirects.
FRONTEND_URL="http://localhost:3000"
# Optional. Public-facing API URL for verification links / OAuth callbacks.
# Defaults to BETTER_AUTH_URL. Set this when the API is reachable on a
# different hostname than what the auth server advertises (e.g. behind a CDN).
# PUBLIC_URL="http://localhost:3001"

# --- Auth ------------------------------------------------------------------
# Required. HMAC secret used to sign Better Auth sessions. Must be at least
# 32 characters; rotate by changing this value (logs everyone out).
BETTER_AUTH_SECRET="your-secret-at-least-32-chars-long"
# Required. Issuer URL Better Auth uses to mint and verify session tokens.
BETTER_AUTH_URL="http://localhost:3001"

# --- Email -----------------------------------------------------------------
# Required. Selects the transport for transactional email (OTPs, invitations,
# new-device alerts, in-app feedback). Allowed values: "ses" | "smtp".
EMAIL_PROVIDER="smtp"
# Required. From address used on every outbound email. The domain must be
# verified with the chosen provider.
TRANSACTIONAL_EMAIL_FROM="noreply@example.com"

# Required when EMAIL_PROVIDER="smtp". Pair these with a local catcher
# (MailHog/Mailpit on 1025) in dev or a real relay in prod.
SMTP_HOST="localhost"
SMTP_PORT="1025"
# Optional auth (both must be set together, or both empty for unauth relays).
SMTP_USERNAME=""
SMTP_PASSWORD=""

# Required when EMAIL_PROVIDER="ses". AWS region of the SES account.
# SES_REGION="eu-central-1"
# Optional credentials. When omitted, the SDK default credential chain is
# used (IAM role, env vars, AWS_PROFILE, etc.) — preferred for prod.
# SES_ACCESS_KEY_ID=""
# SES_SECRET_ACCESS_KEY=""

# --- Object storage (S3 / MinIO) -------------------------------------------
# Required. Endpoint, bucket, and region for file storage. In dev, MinIO runs
# from docker-compose; in prod, point at S3 or any S3-compatible service.
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="stella"
S3_REGION="us-east-1"
# Optional credentials. Omit both to use the SDK default credential chain
# (IAM role on Fargate, AWS_PROFILE locally, etc.).
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# --- Analytics (PostHog) ---------------------------------------------------
# Optional. Key prefix "phc_" without a real id disables capture; useful for
# local development without polluting prod analytics.
POSTHOG_KEY="phc_"
POSTHOG_HOST="https://eu.i.posthog.com"
# Optional. Force-enable PostHog from localhost when using a real key (off
# by default to keep local sessions out of prod dashboards).
# POSTHOG_LOCAL_DEBUG="true"
# Optional. Include raw AI prompts/outputs in localhost LLM events (debugging
# only — leaks user content if pointed at a shared project).
# POSTHOG_LOCAL_DEBUG_AI_CONTENT="true"

# --- AI --------------------------------------------------------------------
# Optional. Default chat/reasoning models route through Google AI; supply a
# key here OR set USE_MOCK_AI="true" to short-circuit prompts in tests/dev.
GOOGLE_GENERATIVE_AI_API_KEY="key-test"
# Optional. Returns canned responses instead of hitting the upstream model
# (CI, smoke tests, offline dev).
USE_MOCK_AI="true"

# --- Content encryption -----------------------------------------------------
# Optional. AES key (32 bytes hex-encoded) used to encrypt extracted file
# text at rest. When unset, extracted content is stored in plaintext.
# Generate with: openssl rand -hex 32
# CONTENT_ENCRYPTION_KEY=""

# --- Social login (optional) ------------------------------------------------
# Required when the matching VITE_AUTH_* flag is enabled on the web app.
# Google: https://console.cloud.google.com/apis/credentials
# GOOGLE_AUTH_CLIENT_ID=""
# GOOGLE_AUTH_CLIENT_SECRET=""
# Microsoft: https://portal.azure.com → App registrations
# MICROSOFT_AUTH_CLIENT_ID=""
# MICROSOFT_AUTH_CLIENT_SECRET=""
# Microsoft tenant ID, or "common" for any work/personal Microsoft account.
# MICROSOFT_AUTH_TENANT_ID="common"

# --- Launch feature flags (optional, default-off) ---------------------------
# Each flag gates server-side routes for the corresponding feature. Pair with
# the VITE_FEATURE_* twin on the web app to also hide UI when disabled.
# FEATURE_CHAT="false"
# FEATURE_BILLING="false"
# FEATURE_KNOWLEDGE_TEMPLATES="false"
# FEATURE_CASE_LAW="false"
# FEATURE_CONTACTS="false"
# FEATURE_CALENDAR="false"
# FEATURE_TODOS="false"
# FEATURE_MCP="false"
# FEATURE_DESKTOP_EDITING="false"

# --- Redis / Valkey ---------------------------------------------------------
# Required. Used for cross-instance SSE broadcasts and rate-limit counters.
REDIS_URL="redis://localhost:6379"

# --- Gotenberg (PDF conversion) ---------------------------------------------
# Required. Sidecar service used to convert DOCX → PDF and other formats.
# In prod, this should be on HTTPS (the env validator enforces it for
# non-localhost hosts).
GOTENBERG_URL="http://localhost:3003"
GOTENBERG_USERNAME="gotenberg"
GOTENBERG_PASSWORD="gotenberg"
