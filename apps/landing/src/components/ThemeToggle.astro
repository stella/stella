<!--
  Theme toggle button with dark/light label swap.
  Include once per page; the script handles the click.
-->
<button
  id="theme-toggle"
  type="button"
  class="cursor-pointer text-sm transition-colors"
  style="color: var(--muted-foreground)"
  aria-label="Toggle theme"
>
  <span class="dark-hidden">Dark</span>
  <span class="light-hidden">Light</span>
</button>

<style>
  .dark-hidden { display: inline; }
  .light-hidden { display: none; }
  :global(.dark) .dark-hidden { display: none; }
  :global(.dark) .light-hidden { display: inline; }
</style>

<script is:inline>
  document.querySelector("#theme-toggle").addEventListener("click", function() {
    var d = document.documentElement.classList;
    var isDark = d.contains("dark");
    var systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    d.toggle("dark", !isDark);
    // If toggling back to what the system prefers, clear the override
    if ((!isDark && systemDark) || (isDark && !systemDark)) {
      localStorage.removeItem("theme");
    } else {
      localStorage.setItem("theme", isDark ? "light" : "dark");
    }
  });
</script>
