---
import Base from "../layouts/Base.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<Base>
  <!-- Brand accent line -->
  <div class="h-[2px]" style="background: linear-gradient(to right, var(--auth-gradient-end), transparent 70%)" data-no-transition></div>

  <main>
    <!-- ——— Hero ——— -->
    <section class="relative flex min-h-screen flex-col overflow-hidden">
      <nav class="relative z-10 mx-auto flex w-full max-w-[1200px] items-center justify-between px-6 py-5">
        <img src="/images/stella-logo.svg" alt="Stella" class="h-6 dark:invert" />
        <div class="flex items-center gap-4">
          <ThemeToggle />
          <a
            href="https://app.stll.app"
            class="text-sm font-medium transition-colors"
            style="color: var(--muted-foreground)"
          >
            Start free &rarr;
          </a>
        </div>
      </nav>

      <div class="relative z-10 flex flex-1 flex-col items-center justify-center px-6 pb-16">
        <h1 class="max-w-3xl text-center font-display text-5xl font-medium leading-[1.08] sm:text-6xl lg:text-7xl">
          Legal workspace.<br />Open source.
        </h1>
        <p class="mt-6 max-w-lg text-center text-lg leading-[1.7]" style="color: var(--muted-foreground)">
          Documents, matters, and research in one place.
          <br />
          Free core, usage&#8209;based AI, no&#160;lock&#8209;in.
        </p>
        <a
          href="https://app.stll.app"
          class="mt-8 inline-flex h-9 items-center rounded-[0.625rem] px-4 text-sm font-medium transition-opacity hover:opacity-90"
          style="background: var(--primary); color: var(--primary-foreground)"
        >
          Start free
        </a>
      </div>

      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3"
        style="background: linear-gradient(to bottom, transparent, var(--auth-gradient-end))"
             ></div>
    </section>

    <!-- ——— Product ——— -->
    <section class="-mt-24 relative z-10 px-6 pb-16">
      <div class="mx-auto max-w-[1200px]">
        <div
          class="flex aspect-video items-center justify-center overflow-hidden rounded-2xl shadow-2xl"
          style="background: var(--card); border: 1px solid var(--border)"
        >
          <span class="select-none text-lg" style="color: var(--muted-foreground)">
            Product screenshot
          </span>
        </div>
      </div>
    </section>

    <!-- ——— Value propositions ——— -->
    <section class="px-6 py-16 lg:py-20">
      <div class="mx-auto grid max-w-[1200px] grid-cols-1 gap-5 md:grid-cols-3">
        {[
          {
            title: "Your data, your control",
            body: "Self&#8209;host or use our cloud. EU\u00A0data residency. BYOK\u00A0encryption."
          },
          {
            title: "Free forever",
            body: "Unlimited users. Documents, matters, search. No\u00A0feature gates."
          },
          {
            title: "Open source",
            body: "Standard formats. Full export. Inspect every line of\u00A0code."
          },
        ].map((card) => (
          <div class="rounded-2xl p-7" style="background: var(--card); border: 1px solid var(--border)">
            <h3 class="mb-2 font-display text-lg font-medium">{card.title}</h3>
            <p class="text-sm leading-[1.7]" style="color: var(--muted-foreground)" set:html={card.body} />
          </div>
        ))}
      </div>
    </section>

    <!-- ——— AI ——— -->
    <section class="px-6 py-16 lg:py-20">
      <div class="mx-auto max-w-[1200px]">
        <div class="mx-auto max-w-2xl text-center">
          <p class="mb-3 text-xs font-medium uppercase tracking-[0.2em]" style="color: var(--muted-foreground)">Intelligence</p>
          <h2 class="font-display text-3xl font-medium leading-tight sm:text-4xl">
            AI that cites its sources.
          </h2>
          <p class="mt-4 text-base leading-[1.7]" style="color: var(--muted-foreground)">
            Review, research, and draft with AI grounded in your
            firm&#8217;s knowledge. Pay only for what you use.
          </p>
        </div>
        <div
          class="mt-10 flex aspect-video items-center justify-center overflow-hidden rounded-2xl shadow-2xl"
          style="background: var(--card); border: 1px solid var(--border)"
        >
          <span class="select-none text-lg" style="color: var(--muted-foreground)">
            AI screenshot
          </span>
        </div>
      </div>
    </section>

    <!-- ——— Pricing ——— -->
    <section class="px-6 py-16 lg:py-20">
      <div class="mx-auto max-w-[1200px]">
        <p class="mb-3 text-center text-xs font-medium uppercase tracking-[0.2em]" style="color: var(--muted-foreground)">Pricing</p>
        <h2 class="mb-10 text-center font-display text-3xl font-medium sm:text-4xl">
          Simple, transparent.
        </h2>
        <div class="mx-auto grid max-w-3xl grid-cols-1 gap-6 md:grid-cols-2">
          {[
            { name: "Standard", price: "Free", features: ["Unlimited users", "Document management", "Matters\u00A0&\u00A0search", "Self\u2011hosting", "Community support"] },
            { name: "Pro", price: "Usage\u2011based", features: ["Everything in Standard", "AI review\u00A0&\u00A0research", "Automated drafting", "Priority support"] },
          ].map((tier) => (
            <a
              href="https://app.stll.app"
              class="pricing-card group flex flex-col rounded-2xl p-8 no-underline transition-all duration-200"
              style="background: var(--card); border: 1px solid var(--border); color: inherit"
            >
              <p class="text-xs font-medium uppercase tracking-[0.15em]" style="color: var(--muted-foreground)">{tier.name}</p>
              <p class="tabular-nums mt-2 font-display text-3xl font-medium">{tier.price}</p>
              <div class="my-6 h-px" style="background: var(--border)"></div>
              <div class="flex-1 space-y-1.5 text-sm leading-[1.7]" style="color: var(--muted-foreground)">
                {tier.features.map((f) => <p set:html={f} />)}
              </div>
              <span
                class="mt-8 inline-flex h-9 items-center self-start rounded-[0.625rem] px-4 text-sm font-medium"
                style="background: var(--primary); color: var(--primary-foreground)"
              >
                Start free
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ——— Trust ——— -->
    <section class="px-6 py-16 lg:py-20">
      <div class="mx-auto max-w-[1200px]">
        <div class="grid grid-cols-1 gap-10 text-center md:grid-cols-3 md:gap-8">
          {[
            { label: "Compliance", title: "Confidential by design", body: "Built in the\u00A0EU. Data stays where you\u00A0decide.", href: "https://docs.stll.app/security", linkText: "Security docs \u2192" },
            { label: "Scale", title: "Enterprise Ready", body: "SSO, audit logs, data residency, BYOK.", href: "https://docs.stll.app", linkText: "Documentation \u2192" },
            { label: "Trust", title: "Transparent", body: "Fully open source. You see exactly what\u00A0runs.", href: "https://github.com/stella/stella", linkText: "View source \u2192" },
          ].map((item) => (
            <div>
              <p class="mb-1 text-xs font-medium uppercase tracking-[0.2em]" style="color: var(--muted-foreground)">{item.label}</p>
              <p class="font-display text-lg font-medium">{item.title}</p>
              <p class="mt-1 text-sm leading-[1.7]" style="color: var(--muted-foreground)" set:html={item.body} />
              <a
                href={item.href}
                class="mt-2 inline-block text-sm font-medium transition-opacity hover:opacity-70"
                style="color: var(--muted-foreground)"
                target={item.href.startsWith("https://github") ? "_blank" : undefined}
                rel={item.href.startsWith("https://github") ? "noopener noreferrer" : undefined}
              >
                {item.linkText}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <!-- ——— Footer ——— -->
  <footer class="relative px-6 py-12" style="border-top: 1px solid var(--border)">
    <div class="mx-auto max-w-[1200px]">
      <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
        <nav class="flex items-center gap-4 text-sm" style="color: var(--muted-foreground)" aria-label="Footer">
          <a href="https://docs.stll.app" class="transition-opacity hover:opacity-70">Docs</a>
          <a href="https://github.com/stella/stella" class="transition-opacity hover:opacity-70" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://status.stll.app" class="transition-opacity hover:opacity-70">Status</a>
          <a href="/terms" class="transition-opacity hover:opacity-70">Terms</a>
          <a href="mailto:contact@stll.app" class="transition-opacity hover:opacity-70">Contact</a>
        </nav>
        <div class="flex items-center gap-4" aria-label="Social">
          <a
            href="https://x.com/stellaworkspace"
            class="transition-opacity hover:opacity-70"
            style="color: var(--muted-foreground)"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a
            href="https://linkedin.com/company/stellaworkspace"
            class="transition-opacity hover:opacity-70"
            style="color: var(--muted-foreground)"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
      <p class="mt-6 text-center text-sm sm:text-left" style="color: var(--muted-foreground)">
        <a href="/imprint" class="transition-opacity hover:opacity-70">stella labs, s.r.o.</a> &#183; Built in the&#160;EU.
      </p>
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32"
      style="background: linear-gradient(to bottom, transparent, var(--auth-gradient-end))"
         ></div>
  </footer>

  <style>
    .pricing-card { cursor: pointer; }
    .pricing-card:hover {
      border-color: var(--primary) !important;
      box-shadow: 0 0 0 1px var(--primary);
      transform: translateY(-2px);
    }
  </style>
</Base>
