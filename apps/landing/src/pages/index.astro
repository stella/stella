        >
      </p>
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-32"
      style="background: linear-gradient(to bottom, transparent, color-mix(in srgb, var(--auth-gradient-end) 42%, transparent))"
    >
