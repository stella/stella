---
import Base from "../layouts/Base.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<Base title="Imprint — stella" description="Legal information.">
  <div class="flex min-h-dvh flex-col">
    <nav class="mx-auto flex w-full max-w-[1200px] items-center justify-between px-6 py-5">
      <a href="/">
        <img src="/images/stella-logo.svg" alt="stella" class="h-6 dark:invert" />
      </a>
      <div class="flex items-center gap-4">
        <ThemeToggle />
        <a
          href="https://app.stll.app"
          class="text-sm font-medium transition-colors whitespace-nowrap"
          style="color: var(--muted-foreground)"
        >
          Start free &rarr;
        </a>
      </div>
    </nav>

    <div class="flex flex-1 items-center justify-center px-6">
      <div class="w-full max-w-[1200px] grid grid-cols-1 gap-16 py-16 md:grid-cols-2 md:gap-24">
        <div>
          <h1 class="font-display text-4xl font-medium tracking-tight sm:text-5xl">
            Imprint
          </h1>
          <p class="mt-4 text-base leading-relaxed" style="color: var(--muted-foreground)">
            Legal information about the company behind stella.
          </p>
        </div>
        <div class="space-y-8 text-sm leading-relaxed" style="color: var(--muted-foreground)">
          <div>
            <p class="mb-1 text-xs font-medium uppercase tracking-wider" style="color: var(--foreground); opacity: 0.5">Company</p>
            <p style="color: var(--foreground)">stella labs, s.r.o.</p>
            <p>A limited liability company established under the laws of the Czech Republic.</p>
          </div>
          <div>
            <p class="mb-1 text-xs font-medium uppercase tracking-wider" style="color: var(--foreground); opacity: 0.5">Registered office</p>
            <p>Nad Porubkou 2355, Poruba</p>
            <p>708 00 Ostrava, Czech Republic</p>
          </div>
          <div>
            <p class="mb-1 text-xs font-medium uppercase tracking-wider" style="color: var(--foreground); opacity: 0.5">Registration</p>
            <p>IČO: 24632872</p>
            <p>Commercial Register maintained by the Regional Court in Ostrava, Section C, File No. 103233</p>
          </div>
          <div>
            <p class="mb-1 text-xs font-medium uppercase tracking-wider" style="color: var(--foreground); opacity: 0.5">Contact</p>
            <p><a href="mailto:contact@stll.app" style="color: var(--foreground)" class="transition-opacity hover:opacity-70">contact@stll.app</a></p>
          </div>
        </div>
      </div>
    </div>

    <footer class="relative px-6 py-12">
      <div class="mx-auto max-w-[1200px] text-center">
        <p class="text-sm" style="color: var(--muted-foreground); opacity: 0.6">
          <a href="/" class="transition-opacity hover:opacity-70">stella labs, s.r.o.</a>
          <span aria-hidden="true"> · </span>
          <a href="/terms" class="transition-opacity hover:opacity-70">Terms</a>
        </p>
      </div>
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-32"
        style="background: linear-gradient(to bottom, transparent, var(--auth-gradient-end))"
      ></div>
    </footer>
  </div>

</Base>
