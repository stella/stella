{
  "extends": "@stll/typescript-config/react-library.json",
  "compilerOptions": {
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@/api/*": ["../api/src/*"], // this is for eden to work https://elysiajs.com/eden/installation#path-alias-monorepo
      "@stll/ares": ["../../packages/ares/src/index.ts"],
      "@stll/docx-core": ["../../packages/docx-core/src/index.ts"],
      "@stll/infosoud": ["../../packages/infosoud/src/index.ts"],
      "@stll/money": ["../../packages/money/src/index.ts"],
      "@stll/ui/*": ["../../packages/ui/src/*"]
    }
  },

  "include": ["src", "vite.config.ts", "vite.config.test.ts", "../../types"],
  "exclude": ["node_modules"]
}
