# Web env validation: apps/web/src/env.ts

# Analytics (phc_ disables PostHog)
VITE_POSTHOG_KEY="phc_"
VITE_POSTHOG_HOST="https://eu.i.posthog.com"
# Optional: enable PostHog capture on localhost for debugging
# VITE_POSTHOG_LOCAL_DEBUG="true"

# API & Rivet
VITE_API_URL="http://localhost:3001"
VITE_RIVET_ENDPOINT="http://localhost:6420/api/rivet"
VITE_RIVET_NAMESPACE="default"

# Social login (set to "true" when the API has credentials configured)
# VITE_AUTH_GOOGLE="false"
# VITE_AUTH_MICROSOFT="false"
