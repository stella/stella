# Web env validation: apps/web/src/env.ts
# Required = Vite refuses to build/serve without it. Optional = unset turns the
# feature off, or falls back to a documented default.

# --- API -------------------------------------------------------------------
# Required. Base URL the SPA targets for Eden treaty calls. The dev-runner
# overrides this at runtime when --port-offset shifts the worktree's API port.
VITE_API_URL="http://localhost:3001"
# Optional. Public web origin used for canonical URLs, Open Graph URLs,
# and sitemap entries. Production deployments should set this to the
# externally reachable app origin.
VITE_PUBLIC_APP_URL="http://localhost:3000"
# Optional. WebSocket URL for the Hocuspocus collaborative editing service.
# Unset keeps Folio on the existing single-user edit-session path.
# VITE_COLLAB_URL="ws://localhost:3002"

# --- Analytics (PostHog) ---------------------------------------------------
# Optional. Key prefix "phc_" without a real id disables capture; safe default
# for local development. Set VITE_POSTHOG_HOST explicitly when enabling
# diagnostics so self-hosted deployments do not quietly phone home.
VITE_POSTHOG_KEY="phc_"
# VITE_POSTHOG_HOST="https://eu.i.posthog.com"
# Optional. Force-enable PostHog from localhost when using a real key.
# VITE_POSTHOG_LOCAL_DEBUG="true"

# --- Social login -----------------------------------------------------------
# Optional, default "false". Set to "true" only when the API has the matching
# {GOOGLE,MICROSOFT}_AUTH_CLIENT_ID/SECRET configured; otherwise the button
# renders a broken flow.
# VITE_AUTH_GOOGLE="false"
# VITE_AUTH_MICROSOFT="false"

# --- Self-host update notice -----------------------------------------------
# Optional, default "false". Set to "true" only on self-hosted deployments
# to enable the in-app banner that polls the public GitHub Releases API
# and surfaces newer stella versions to operators. Off on the hosted
# stll.app SaaS, where customers don't upgrade themselves.
# VITE_SELFHOST="true"

# --- Launch feature flags (optional, default-off) ---------------------------
# Each flag hides UI for the corresponding feature. Pair with the FEATURE_*
# twin on the API to also lock down the server routes.
# VITE_FEATURE_CHAT="false"
# VITE_FEATURE_BILLING="false"
# VITE_FEATURE_KNOWLEDGE_TEMPLATES="false"
# VITE_FEATURE_CASE_LAW="false"
# VITE_PUBLIC_LAW_ENABLED="false"
# VITE_PUBLIC_LAW_INDEXING_ENABLED="false"
# VITE_FEATURE_CONTACTS="false"
# VITE_FEATURE_CALENDAR="false"
# VITE_FEATURE_TODOS="false"
# VITE_FEATURE_MCP="false"
# VITE_FEATURE_DESKTOP_EDITING="false"
# VITE_FEATURE_FOLIO_COLLAB="false"

# --- Legal links -----------------------------------------------------------
# Optional. Absolute URL or root-relative path for the Terms of Service link.
# Defaults to "/terms" so self-hosted and custom-domain deployments stay local.
# VITE_TERMS_URL="/terms"

# --- Feedback button -------------------------------------------------------
# Optional. Recipient email for the in-app feedback button. The button is
# hidden when unset; otherwise it opens the user's mail client with the
# current route prefilled. No SMTP/SES wiring required.
# VITE_FEEDBACK_EMAIL_TO="ops@example.com"

# --- Empty state media -----------------------------------------------------
# Optional. Public CDN/object-storage URL for the Matters onboarding video.
# When unset, the empty state renders the bundled poster image only.
# VITE_EMPTY_STATE_MATTERS_VIDEO_URL="https://assets.stll.app/empty-states/matters-intro.mp4"
