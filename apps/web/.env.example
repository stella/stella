# Web env validation: apps/web/src/env.ts
# Required = Vite refuses to build/serve without it. Optional = unset turns the
# feature off, or falls back to a documented default.

# --- API -------------------------------------------------------------------
# Required. Base URL the SPA targets for Eden treaty calls. The dev-runner
# overrides this at runtime when --port-offset shifts the worktree's API port.
VITE_API_URL="http://localhost:3001"

# --- Analytics (PostHog) ---------------------------------------------------
# Optional. Key prefix "phc_" without a real id disables capture; safe default
# for local development.
VITE_POSTHOG_KEY="phc_"
VITE_POSTHOG_HOST="https://eu.i.posthog.com"
# Optional. Force-enable PostHog from localhost when using a real key.
# VITE_POSTHOG_LOCAL_DEBUG="true"

# --- Social login -----------------------------------------------------------
# Optional, default "false". Set to "true" only when the API has the matching
# {GOOGLE,MICROSOFT}_AUTH_CLIENT_ID/SECRET configured; otherwise the button
# renders a broken flow.
# VITE_AUTH_GOOGLE="false"
# VITE_AUTH_MICROSOFT="false"

# --- Launch feature flags (optional, default-off) ---------------------------
# Each flag hides UI for the corresponding feature. Pair with the FEATURE_*
# twin on the API to also lock down the server routes.
# VITE_FEATURE_CHAT="false"
# VITE_FEATURE_BILLING="false"
# VITE_FEATURE_KNOWLEDGE_TEMPLATES="false"
# VITE_FEATURE_CASE_LAW="false"
# VITE_FEATURE_CONTACTS="false"
# VITE_FEATURE_CALENDAR="false"
# VITE_FEATURE_TODOS="false"
# VITE_FEATURE_MCP="false"
# VITE_FEATURE_DESKTOP_EDITING="false"

# --- Feedback button -------------------------------------------------------
# Optional. Recipient email for the in-app feedback button. The button is
# hidden when unset; otherwise it opens the user's mail client with the
# current route prefilled. No SMTP/SES wiring required.
# VITE_FEEDBACK_EMAIL_TO="ops@example.com"
