{
  "name": "@stll/desktop",
  "version": "0.0.1",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tauri build",
    "build:view": "vite build",
    "clean": "git clean -xdf .cache .turbo dist node_modules src-tauri/target",
    "dev": "tauri dev",
    "dev:view": "vite --host 127.0.0.1 --strictPort",
    "format": "oxfmt -c ../../.oxfmtrc.json .",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware apps/desktop",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix apps/desktop",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@stll/ui": "workspace:*",
    "@tauri-apps/api": "^2.11.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "use-intl": "catalog:"
  },
  "devDependencies": {
    "@stll/typescript-config": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "^2.11.1",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
