{
  "name": "@stella/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build && electrobun build",
    "build:view": "vite build",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "bun run scripts/dev.ts",
    "dev:app": "bun run build:view && electrobun dev --watch",
    "dev:view": "vite --host 127.0.0.1 --strictPort",
    "format": "oxfmt -c ../../.oxfmtrc.json .",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware apps/desktop",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware --fix apps/desktop",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@stella/ui": "workspace:*",
    "electrobun": "1.16.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "devDependencies": {
    "@stella/typescript-config": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/bun": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "^6.0.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
