{
  "name": "@stella/desktop",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cargo tauri build",
    "build:view": "vite build",
    "clean": "git clean -xdf .cache .turbo dist node_modules src-tauri/target",
    "dev": "cargo tauri dev",
    "dev:view": "vite --host 127.0.0.1 --strictPort",
    "format": "oxfmt -c ../../.oxfmtrc.json .",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware apps/desktop",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware --fix apps/desktop",
    "test": "bun test --pass-with-no-tests",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@stella/ui": "workspace:*",
    "@tauri-apps/api": "^2.5.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "use-intl": "catalog:"
  },
  "devDependencies": {
    "@stella/typescript-config": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
