{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/v2/crates/tauri-cli/schema.json",
  "productName": "stella desktop",
  "version": "0.0.1",
  "identifier": "legal.stella.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5177",
    "beforeDevCommand": "bun run dev:view",
    "beforeBuildCommand": "bun run build:view"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/tray-icon-32-template.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "Stella Dev"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["stella"]
      }
    }
  }
}
