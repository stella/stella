{
  "name": "@stella/rivet",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./consts": "./src/consts.ts",
    "./actors/*": "./src/actors/*.ts",
    "./types": "./src/types.ts",
    "./errors": "./src/errors.ts",
    "./timeout": "./src/timeout.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "typecheck": "tsgo --noEmit",
    "lint": "bun --bun oxlint --type-aware",
    "lint:fix": "bun --bun oxlint --type-aware --fix",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@rivetkit/framework-base": "catalog:rivet",
    "better-result": "catalog:",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
