{
  "name": "@stll/business-registries",
  "version": "0.1.0",
  "description": "Typed clients for national business / commercial registries (Czech ARES, Norwegian Brreg, US SEC EDGAR, Slovak ORSR, Taiwanese GCIS, Finnish PRH, Polish KRS, UK Companies House, French INSEE Sirene, ...)",
  "keywords": [
    "ares",
    "brreg",
    "business-register",
    "commercial-register",
    "companies-house",
    "company-lookup",
    "edgar",
    "gcis",
    "krs",
    "legal",
    "obchodny-register",
    "orsr",
    "prh",
    "registry",
    "sec",
    "sirene",
    "vat",
    "vies"
  ],
  "homepage": "https://github.com/stella/stella/tree/main/packages/business-registries",
  "bugs": {
    "url": "https://github.com/stella/stella/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/stella.git",
    "directory": "packages/business-registries"
  },
  "files": [
    ".github/assets/banner.png",
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./ares": {
      "bun": "./src/ares/index.ts",
      "types": "./src/ares/index.ts",
      "import": "./dist/ares/index.js"
    },
    "./brreg": {
      "bun": "./src/brreg/index.ts",
      "types": "./src/brreg/index.ts",
      "import": "./dist/brreg/index.js"
    },
    "./companies-house": {
      "bun": "./src/companies-house/index.ts",
      "types": "./src/companies-house/index.ts",
      "import": "./dist/companies-house/index.js"
    },
    "./edgar": {
      "bun": "./src/edgar/index.ts",
      "types": "./src/edgar/index.ts",
      "import": "./dist/edgar/index.js"
    },
    "./gcis": {
      "bun": "./src/gcis/index.ts",
      "types": "./src/gcis/index.ts",
      "import": "./dist/gcis/index.js"
    },
    "./krs": {
      "bun": "./src/krs/index.ts",
      "types": "./src/krs/index.ts",
      "import": "./dist/krs/index.js"
    },
    "./orsr": {
      "bun": "./src/orsr/index.ts",
      "types": "./src/orsr/index.ts",
      "import": "./dist/orsr/index.js"
    },
    "./prh": {
      "bun": "./src/prh/index.ts",
      "types": "./src/prh/index.ts",
      "import": "./dist/prh/index.js"
    },
    "./recherche-entreprises": {
      "bun": "./src/recherche-entreprises/index.ts",
      "types": "./src/recherche-entreprises/index.ts",
      "import": "./dist/recherche-entreprises/index.js"
    },
    "./vies": {
      "bun": "./src/vies/index.ts",
      "types": "./src/vies/index.ts",
      "import": "./dist/vies/index.js"
    },
    "./shared": {
      "bun": "./src/shared/index.ts",
      "types": "./src/shared/index.ts",
      "import": "./dist/shared/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "git clean -xdf dist .cache .turbo node_modules",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "pack:dry-run": "bun pm pack --dry-run",
    "test": "bun test src",
    "typecheck": "tsgo --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware packages/business-registries",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix packages/business-registries",
    "format": "oxfmt .",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@stll/country-codes": "workspace:*",
    "@stll/stdnum": "^2.0.1"
  },
  "devDependencies": {
    "@stll/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
