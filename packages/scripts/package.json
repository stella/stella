{
  "name": "@stll/scripts",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "bin": {
    "i18n-check": "src/i18n-check.ts",
    "i18n-typegen": "src/i18n-typegen.ts"
  },
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "test": "bun test",
    "typecheck": "tsgo --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware packages/scripts",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware --fix packages/scripts",
    "format": "oxfmt ."
  },
  "devDependencies": {
    "@stll/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
