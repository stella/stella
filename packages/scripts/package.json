{
  "name": "@stll/scripts",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "bin": {
    "glossary-gen": "src/glossary-gen.ts",
    "i18n-check": "src/i18n-check.ts",
    "i18n-lint": "src/i18n-lint.ts",
    "i18n-typegen": "src/i18n-typegen.ts"
  },
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware packages/scripts",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix packages/scripts",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@formatjs/icu-messageformat-parser": "^3.5.12",
    "@stll/ai-catalog": "workspace:*",
    "better-result": "catalog:"
  },
  "devDependencies": {
    "@stll/typescript-config": "workspace:*",
    "@types/bun": "catalog:"
  }
}
