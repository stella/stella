{
  "name": "@stll/folio",
  "version": "0.1.0",
  "private": true,
  "description": "A modern .docx-compatible document editor for the browser",
  "license": "Apache-2.0",
  "author": "STLL",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./editor.css": "./src/styles/editor.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --type-aware packages/folio",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix packages/folio",
    "format": "oxfmt .",
    "test": "bun test src",
    "test:visual": "bunx playwright test",
    "test:visual:update": "bunx playwright test --update-snapshots",
    "test:visual:report": "bunx playwright show-report"
  },
  "dependencies": {
    "@fontsource/arimo": "^5.2.8",
    "@fontsource/caladea": "^5.2.8",
    "@fontsource/carlito": "^5.2.8",
    "@fontsource/cousine": "^5.2.7",
    "@fontsource/tinos": "^5.2.7",
    "@stll/docx-core": "workspace:*",
    "@stll/docx-utils": "workspace:*",
    "@stll/ui": "workspace:*",
    "fast-xml-parser": "^5.7.2",
    "jszip": "catalog:",
    "lucide-react": "catalog:",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.5.0",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-state": "^1.4.4",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "utif2": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "fast-check": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "use-intl": ">=4.0.0"
  }
}
