{
  "name": "@stll/cli",
  "version": "0.3.0",
  "description": "Stella command-line client",
  "keywords": [
    "cli",
    "legal",
    "stella",
    "tanstack-intent"
  ],
  "homepage": "https://github.com/stella/stella/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/stella/stella/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/stella.git",
    "directory": "packages/cli"
  },
  "bin": {
    "stella": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "skills",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/cli.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "git clean -xdf dist .cache .turbo node_modules",
    "codegen": "cd ../../apps/api && bun scripts/export-mcp-tool-registry.ts && cd ../../packages/cli && bun run src/codegen.ts && oxfmt .",
    "build": "rm -rf dist && bun ../../packages/scripts/src/tsc-native.ts -p tsconfig.build.json && cp src/generated/registry-snapshot.json dist/generated/registry-snapshot.json && cp src/generated/capability-catalog.json dist/generated/capability-catalog.json && printf '%s\\n' '#!/usr/bin/env node' > dist/cli.js.tmp && tail -n +2 dist/cli.js >> dist/cli.js.tmp && mv dist/cli.js.tmp dist/cli.js && chmod +x dist/cli.js",
    "prepack": "bun run build",
    "pack:dry-run": "bun pm pack --dry-run",
    "test": "bun test src",
    "typecheck": "bun ../../packages/scripts/src/tsc-native.ts --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware packages/cli",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix packages/cli",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@stricli/core": "^1.3.0",
    "better-result": "catalog:",
    "mime-types": "catalog:",
    "re2-wasm": "^1.0.2",
    "valibot": "catalog:"
  },
  "devDependencies": {
    "@stll/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/mime-types": "^3.0.1"
  },
  "engines": {
    "node": ">=20"
  }
}
