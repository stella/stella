{
  "name": "@stella/extension",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "prepare": "wxt prepare",
    "typecheck": "wxt prepare && tsgo --noEmit",
    "lint": "wxt prepare && cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware packages/extension",
    "lint:fix": "wxt prepare && cd ../.. && bun --bun oxlint -c oxlint.config.mjs --type-aware --fix packages/extension",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@stella/ui": "workspace:*",
    "react": "catalog:react19",
    "react-dom": "catalog:react19"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/chrome": "^0.1.40",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@wxt-dev/module-react": "^1.2.2",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "wxt": "^0.20.23"
  }
}
