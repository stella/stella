{
  "name": "@stll/transactional",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    "./emails/*": "./emails/*.tsx"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "build": "email build",
    "dev": "email dev -p 3002",
    "export": "email export",
    "start": "email start -p 3002",
    "typecheck": "tsgo --noEmit",
    "typegen": "bun ../scripts/src/i18n-typegen.ts i18n/langs",
    "i18n:check": "bun ../scripts/src/i18n-typegen.ts i18n/langs --check && bun ../scripts/src/i18n-check.ts i18n/langs",
    "i18n:sync": "bun ../scripts/src/i18n-check.ts i18n/langs --sync && bun ../scripts/src/i18n-typegen.ts i18n/langs",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware packages/transactional",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix packages/transactional",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "react": "catalog:react19",
    "use-intl": "catalog:"
  },
  "devDependencies": {
    "@react-email/ui": "6.1.1",
    "@stll/typescript-config": "workspace:*",
    "@types/react": "catalog:react19",
    "react-email": "^6.1.1",
    "typescript": "catalog:"
  }
}
