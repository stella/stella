{
  "name": "@stella/transactional",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./emails/*": "./emails/*.tsx"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "build": "email build",
    "dev": "email dev -p 3002",
    "export": "email export",
    "start": "email start -p 3002",
    "typecheck": "tsgo --noEmit",
    "typegen": "bun ../scripts/src/i18n-typegen.ts i18n/langs",
    "i18n:check": "bun ../scripts/src/i18n-check.ts i18n/langs",
    "lint": "bun --bun oxlint --type-aware",
    "lint:fix": "bun --bun oxlint --type-aware --fix",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "use-intl": "catalog:"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.8",
    "@stella/scripts": "workspace:*",
    "@stella/typescript-config": "workspace:*",
    "@types/react": "catalog:react19",
    "react-email": "5.2.8",
    "typescript": "catalog:"
  }
}
