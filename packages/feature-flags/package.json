{
  "name": "@stll/feature-flags",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "typecheck": "tsgo --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware packages/feature-flags",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix packages/feature-flags",
    "format": "oxfmt ."
  },
  "devDependencies": {
    "@stll/typescript-config": "workspace:*",
    "typescript": "catalog:"
  }
}
