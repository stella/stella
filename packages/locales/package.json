{
  "name": "@stll/locales",
  "version": "0.1.0",
  "description": "ISO 639-1 living languages — single canonical list, derived UI-locale subset, and resolver helpers",
  "keywords": [
    "bcp-47",
    "i18n",
    "iso-639",
    "language",
    "locale"
  ],
  "homepage": "https://github.com/stella/stella/tree/main/packages/locales",
  "bugs": {
    "url": "https://github.com/stella/stella/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stella/stella.git",
    "directory": "packages/locales"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "git clean -xdf dist .cache .turbo node_modules",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "pack:dry-run": "bun pm pack --dry-run",
    "test": "bun test src",
    "typecheck": "tsgo --noEmit",
    "lint": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --report-unused-disable-directives-severity=error --deny-warnings --type-aware packages/locales",
    "lint:fix": "cd ../.. && bun --bun oxlint -c oxlint.config.ts --type-aware --fix packages/locales",
    "format": "oxfmt .",
    "prepack": "bun run build"
  },
  "devDependencies": {
    "@stll/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
