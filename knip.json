{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts", "i18n-unused.config.js", "oxlint.config.ts"],
      "ignoreDependencies": [
        "@tanstack/eslint-plugin-query",
        "@tanstack/eslint-plugin-router",
        "eslint",
        "eslint-plugin-drizzle",
        "eslint-plugin-sonarjs",
        "oxlint-tsgolint",
        "ultracite",
        "i18n-unused",
        "oxlint",
        "vite"
      ],
      "ignoreBinaries": ["scripts/dev.sh"]
    },
    "apps/api": {
      "entry": [
        "src/index.ts!",
        "src/handlers/files/pdf-worker.ts!",
        "src/lib/search/extraction-worker.ts!",
        "scripts/*.ts",
        "src/scripts/*.ts",
        "src/dev/register-mock-ai.ts",
        "src/lib/__fixtures__/*.ts",
        "src/handlers/case-law/seed-court-weights.ts",
        "src/handlers/case-law/ingestion/adapters/health-check.ts",
        "src/handlers/case-law/ingestion/adapters/update-fixtures.ts",
        "src/handlers/docx/generate-sample.ts",
        "src/handlers/docx/generate-samples.ts",
        "src/handlers/docx/generate-spa-filled.ts",
        "src/handlers/docx/prepare-spa-template.ts",
        "src/tests/load/*.ts",
        "drizzle.config.ts"
      ],
      "ignoreDependencies": ["@electric-sql/pglite"]
    },
    "apps/web": {
      "entry": ["src/main.tsx", "src/server.ts!", "vite.config.ts"],
      "ignore": [
        "public/dark-mode-init.js",
        "src/routeTree.gen.ts",
        "src/lib/anonymize/gazetteer.ts",
        "src/lib/anonymize/pdf-content-stream.ts",
        "src/lib/anonymize/pdf-redact.ts",
        "src/lib/anonymize/redaction-map.ts",
        "src/lib/pdf/use-anonymized-field-ids.ts"
      ],
      "ignoreDependencies": ["react-grab", "@libpdf/core", "idb"]
    },
    "apps/docs": {
      "entry": [
        "src/**/*.astro",
        "src/content.config.ts",
        "src/styles/custom.css",
        "astro.config.*"
      ]
    },
    "apps/landing": {
      "entry": [
        "src/**/*.astro",
        "src/content.config.ts",
        "src/pages/**/*.ts",
        "astro.config.*",
        "postcss.config.mjs"
      ],
      "ignoreDependencies": ["@tailwindcss/postcss"]
    },
    "apps/legal-atlas-runner": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "ignoreDependencies": ["@stll/api"]
    },
    "packages/legal-atlas": {
      "entry": ["src/index.ts", "src/**/*.test.ts"]
    },
    "packages/legal-ast": {
      "entry": ["src/index.ts", "src/**/*.test.ts"]
    },
    "packages/permissions": {
      "entry": ["src/index.ts"]
    },
    "packages/scripts": {
      "entry": ["src/i18n-check.ts", "src/i18n-typegen.ts"]
    },
    "packages/template-conditions": {
      "entry": ["src/index.ts", "src/**/*.test.ts"]
    },
    "packages/transactional": {
      "entry": ["emails/*.tsx"],
      "ignoreDependencies": ["react-dom", "@react-email/preview-server"]
    },
    "packages/ui": {
      "entry": [
        "src/components/*.tsx",
        "src/hooks/*.ts",
        "src/lib/*.ts",
        "src/styles/globals.css"
      ]
    },
    "packages/folio": {
      "entry": ["src/index.ts", "src/styles/*.css"],
      "ignore": ["src/**/*.test.ts", "src/**/*.test.tsx", "tests/**"]
    }
  },
  "ignore": [".oxlint-plugins/**", ".claude/**"],
  "ignoreIssues": {
    "packages/folio/src/core/managers/ClipboardManager.ts": ["duplicates"],
    "packages/infosoud/src/constants.ts": ["duplicates"]
  },
  "exclude": ["exports", "types"],
  "ignoreBinaries": ["docker", "oxfmt", "tsgo", "bun", "tail"],
  "ignoreDependencies": ["@stll/typescript-config"],
  "ignoreWorkspaces": ["packages/skills", "packages/typescript-config"]
}
