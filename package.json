{
  "name": "stella",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "resolutions": {
    "@emnapi/core": "1.9.1",
    "@emnapi/runtime": "1.9.1",
    "prosemirror-transform": "1.12.0",
    "prosemirror-view": "1.41.8"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "bun packages/scripts/src/dev-runner.ts dev",
    "dev:ai-tools": "bun --cwd apps/api dev:ai-tools",
    "dev:all": "turbo dev",
    "dev:api": "bun packages/scripts/src/dev-runner.ts dev:api",
    "dev:desktop": "bun packages/scripts/src/dev-runner.ts dev:desktop",
    "dev:web": "bun packages/scripts/src/dev-runner.ts dev:web",
    "typegen": "turbo run typegen",
    "typecheck": "turbo run typecheck",
    "secrets:check:staged": "bash scripts/check-staged-secrets.sh",
    "sync-ai": "bash scripts/sync-ai-skills.sh",
    "link-codex": "bash scripts/link-codex-skills.sh",
    "format": "turbo run format",
    "format:check": "turbo run format -- --check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "lint:ws": "sherif -r unsync-similar-dependencies && bun packages/scripts/src/workspace-hygiene.ts",
    "i18n:check": "turbo run i18n:check --",
    "i18n:sync": "turbo run i18n:check -- --sync",
    "test": "turbo run test",
    "clean": "turbo run clean && git clean -xdf node_modules",
    "sync:well-known": "cp -r .well-known apps/web/public/",
    "setup:dev": "bun run dev",
    "setup:dev:api": "bun run dev:api",
    "setup:dev:desktop": "bun run dev:desktop",
    "setup:dev:web": "bun run dev:web",
    "setup:mcp": "bun install --cwd .claude/mcp",
    "hooks:install": "lefthook install",
    "knip": "knip-bun",
    "hooks:uninstall": "lefthook uninstall",
    "postinstall": "bun run lint:ws"
  },
  "devDependencies": {
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@stll/typescript-config": "workspace:^0.0.0",
    "@tanstack/eslint-plugin-query": "catalog:",
    "@tanstack/eslint-plugin-router": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260504.1",
    "eslint": "catalog:",
    "eslint-plugin-drizzle": "catalog:",
    "eslint-plugin-sonarjs": "catalog:",
    "i18n-unused": "^0.19.0",
    "knip": "^6.9.0",
    "lefthook": "^2.1.6",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "^0.22.1",
    "sherif": "catalog:",
    "turbo": "^2.9.6",
    "typescript": "catalog:",
    "ultracite": "catalog:",
    "vite": "catalog:"
  },
  "optionalDependencies": {
    "@typescript/native-preview-darwin-arm64": "7.0.0-dev.20260504.1",
    "@typescript/native-preview-darwin-x64": "7.0.0-dev.20260504.1",
    "@typescript/native-preview-linux-arm": "7.0.0-dev.20260504.1",
    "@typescript/native-preview-linux-arm64": "7.0.0-dev.20260504.1",
    "@typescript/native-preview-linux-x64": "7.0.0-dev.20260504.1",
    "@typescript/native-preview-win32-arm64": "7.0.0-dev.20260504.1",
    "@typescript/native-preview-win32-x64": "7.0.0-dev.20260504.1"
  },
  "packageManager": "bun@1.3.13",
  "catalog": {
    "@base-ui/react": "1.4.1",
    "@better-auth/oauth-provider": "1.6.9",
    "@libpdf/core": "0.3.4",
    "@stll/anonymize-data": "0.0.5",
    "@stll/anonymize-wasm": "1.1.1",
    "@t3-oss/env-core": "0.13.11",
    "@tailwindcss/postcss": "4.2.4",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/eslint-plugin-query": "5.100.6",
    "@tanstack/eslint-plugin-router": "1.161.6",
    "@types/bun": "1.3.13",
    "@vitejs/plugin-react": "^6.0.1",
    "better-auth": "1.6.9",
    "better-result": "2.9.0",
    "diff": "9.0.0",
    "drizzle-kit": "1.0.0-rc.1",
    "drizzle-orm": "1.0.0-rc.1",
    "elysia": "1.4.28",
    "eslint": "10.2.1",
    "eslint-plugin-drizzle": "0.2.3",
    "eslint-plugin-sonarjs": "4.0.3",
    "fast-check": "^4.7.0",
    "jszip": "3.10.1",
    "lucide-react": "1.14.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "sherif": "1.11.1",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "ultracite": "7.6.2",
    "use-intl": "4.11.0",
    "valibot": "1.3.1",
    "vite": "8.0.10"
  },
  "catalogs": {
    "react19": {
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.5",
      "react-dom": "^19.2.5"
    }
  }
}
