{
  "name": "stella",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "resolutions": {
    "@emnapi/core": "1.9.1",
    "@emnapi/runtime": "1.9.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typegen": "turbo run typegen",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "format:check": "turbo run format -- --check",
    "lint": "turbo run lint",
    "lint:ws": "bunx sherif@latest -r unsync-similar-dependencies",
    "i18n:check": "turbo run i18n:check --",
    "test": "turbo run test",
    "clean": "turbo run clean && git clean -xdf node_modules",
    "sync:well-known": "cp -r .well-known apps/web/public/",
    "setup:dev": "scripts/dev.sh",
    "setup:mcp": "bun install --cwd .claude/mcp",
    "hooks:install": "lefthook install",
    "hooks:uninstall": "lefthook uninstall",
    "postinstall": "bun run lint:ws"
  },
  "devDependencies": {
    "@stella/typescript-config": "workspace:^0.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "i18n-unused": "^0.19.0",
    "lefthook": "^2.1.4",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "^0.16.0",
    "turbo": "^2.8.20",
    "typescript": "catalog:",
    "ultracite": "catalog:",
    "vite": "catalog:"
  },
  "packageManager": "bun@1.3.10",
  "catalog": {
    "@base-ui/react": "1.3.0",
    "@t3-oss/env-core": "0.13.11",
    "@types/bun": "1.3.11",
    "@types/diff-match-patch": "1.0.36",
    "better-auth": "1.5.6",
    "better-result": "2.7.0",
    "diff-match-patch": "1.0.5",
    "@libpdf/core": "0.3.4",
    "elysia": "1.4.28",
    "lucide-react": "1.6.0",
    "nanoid": "5.1.7",
    "tailwindcss": "4.2.2",
    "oxfmt": "0.42.0",
    "oxlint": "1.55.0",
    "typescript": "5.9.3",
    "ultracite": "7.3.2",
    "use-intl": "4.8.3",
    "valibot": "1.2.0",
    "vite": "8.0.2"
  },
  "catalogs": {
    "react19": {
      "@types/node": "^25.3.2",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    },
    "rivet": {
      "@rivetkit/react": "2.1.6",
      "rivetkit": "2.1.6"
    }
  }
}
