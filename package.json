{
  "name": "stella",
  "version": "0.0.0",
  "devDependencies": {
    "@biomejs/biome": "catalog:ultracite",
    "@stella/prettier-config": "workspace:^0.0.0",
    "@stella/typescript-config": "workspace:^0.0.0",
    "i18n-unused": "^0.19.0",
    "prettier": "catalog:",
    "turbo": "^2.8.14",
    "typescript": "catalog:",
    "ultracite": "catalog:ultracite"
  },
  "catalog": {
    "@base-ui/react": "1.2.0",
    "@t3-oss/env-core": "0.13.10",
    "@tamtamchik/json-deep-sort": "1.4.1",
    "@types/bun": "1.3.9",
    "@types/diff-match-patch": "1.0.36",
    "better-auth": "1.4.20",
    "better-result": "2.7.0",
    "diff-match-patch": "1.0.5",
    "elysia": "1.4.26",
    "lucide-react": "0.575.0",
    "nanoid": "5.1.6",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "use-intl": "4.8.3",
    "valibot": "1.2.0"
  },
  "catalogs": {
    "react19": {
      "@types/node": "^25.3.2",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    },
    "rivet": {
      "@rivetkit/react": "2.1.3",
      "rivetkit": "2.1.3"
    },
    "ultracite": {
      "@biomejs/biome": "2.4.6",
      "ultracite": "7.2.5"
    }
  },
  "license": "AGPL-3.0-only",
  "packageManager": "bun@1.3.6",
  "prettier": "@stella/prettier-config",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typegen": "turbo run typegen",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format format:root --continue -- --cache --cache-location .cache/.prettiercache",
    "format:root": "prettier --check . --ignore-path .gitignore --ignore-path .prettierignore",
    "lint": "turbo run lint",
    "lint:colors": "scripts/lint-colors.sh",
    "lint:logical-properties": "scripts/lint-logical-properties.sh",
    "lint:ws": "bunx sherif@latest -r unsync-similar-dependencies",
    "i18n:check": "turbo run i18n:check --",
    "test": "turbo run test",
    "clean": "turbo run clean && git clean -xdf node_modules",
    "sync:well-known": "cp -r .well-known apps/web/public/",
    "setup:dev": "scripts/dev.sh",
    "setup:mcp": "bun install --cwd .claude/mcp",
    "postinstall": "bun run lint:ws"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
